{
  "manifest_version": 3,
  "name": "NetrunnerDB TOOLS",
  "version": "1.0",
  "description": "NetrunnerDB 工具",
  "permissions": [
    "storage",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "https://netrunnerDB.com/en/deck/edit/*",
    "https://netrunnerDB.com/en/deck/build/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://netrunnerDB.com/en/deck/edit/*",
        "https://netrunnerDB.com/en/deck/build/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end"
    }
  ],
 
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "inject.js"
      ],
      "matches": [
        "https://netrunnerDB.com/*"
      ]
    }
  ]
}